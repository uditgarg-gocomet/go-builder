{
  "name": "@portal/widgets",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@portal/action-runtime": "workspace:*",
    "@portal/core": "workspace:*",
    "@portal/ui": "workspace:*"
  },
  "devDependencies": {
    "@portal/action-runtime": "workspace:*",
    "@portal/core": "workspace:*",
    "@portal/ui": "workspace:*",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-plugin-dts": "^4.3.0"
  }
}
