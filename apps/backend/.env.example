# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres 16 — format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://portal:portal_secret@localhost:5433/portal_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis 7 — format: redis://:password@host:port
REDIS_URL=redis://:redis_secret@localhost:6379

# ─── Secrets ──────────────────────────────────────────────────────────────────
# AES-256-GCM encryption key — 64 hex characters (32 bytes)
# Generate: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# ─── JWT / RS256 ──────────────────────────────────────────────────────────────
# Generate keypair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the PEM content with \n escapes or use multiline env syntax
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KEY_ID=portal-key-1

# Access token TTL in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TTL=900
# Refresh token TTL in seconds (default: 604800 = 7 days)
JWT_REFRESH_TTL=604800

# ─── OpenFGA ──────────────────────────────────────────────────────────────────
OPENFGA_API_URL=http://localhost:8080
OPENFGA_STORE_ID=replace_with_openfga_store_id
OPENFGA_AUTHORIZATION_MODEL_ID=replace_with_openfga_model_id

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── App Renderer ─────────────────────────────────────────────────────────────
# Webhook URL for triggering renderer rebuilds on schema promote
RENDERER_BUILD_WEBHOOK=http://localhost:3002/api/build-webhook
# HMAC-SHA256 secret for signing build webhook payloads
BUILD_WEBHOOK_SECRET=replace_with_random_secret

# ─── Assets ───────────────────────────────────────────────────────────────────
# Local storage path (relative to backend root)
ASSETS_UPLOAD_DIR=./uploads
# Max upload size in bytes (default: 10 MB)
ASSETS_MAX_SIZE_BYTES=10485760
# Public URL base for asset delivery
BACKEND_URL=http://localhost:3001

# Hostnames that bypass the connector SSRF check (comma-separated). Production
# should leave this empty. Set to "localhost,127.0.0.1" for the GoComet V2 demo.
SSRF_ALLOWED_HOSTS=
