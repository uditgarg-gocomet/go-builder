{
  "name": "@portal/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/modules/registry/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@openfga/sdk": "^0.6.3",
    "@portal/widgets": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.40.0",
    "argon2": "^0.41.1",
    "fast-json-patch": "^3.1.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "mime-types": "^3.0.2",
    "openid-client": "^5.7.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "samlify": "^2.8.10",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.2",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
