# ─── Next.js ──────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Core Backend ─────────────────────────────────────────────────────────────
# Internal URL (server-side API calls from Next.js API routes)
BACKEND_INTERNAL_URL=http://localhost:3001
# Public URL (used by client-side code in the browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWKS endpoint for JWT validation (used by Next.js middleware)
JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used by Builder API routes for preview session storage
REDIS_URL=redis://:redis_secret@localhost:6379

# Preview session TTL in seconds (default: 3600 = 1 hour)
PREVIEW_SESSION_TTL=3600

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
