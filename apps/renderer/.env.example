# ─── Next.js ──────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ─── App Identity ─────────────────────────────────────────────────────────────
# The app slug this renderer instance is serving
APP_SLUG=replace_with_app_slug
# The environment this renderer serves
APP_ENVIRONMENT=STAGING

# ─── Core Backend ─────────────────────────────────────────────────────────────
# Internal URL (server-side at build time — schema fetch, auth validation)
BACKEND_INTERNAL_URL=http://localhost:3001
# Public URL (client-side connector execute calls)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWKS endpoint — public key for JWT validation in middleware
JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used by Next.js middleware for token revocation check
REDIS_URL=redis://:redis_secret@localhost:6379

# ─── Build Webhook ────────────────────────────────────────────────────────────
# HMAC-SHA256 secret — must match BUILD_WEBHOOK_SECRET in backend .env
BUILD_WEBHOOK_SECRET=replace_with_random_secret

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
